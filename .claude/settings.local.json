{
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Read",
      "Write",
      "Edit",
      "MultiEdit",
      "Glob",
      "Grep",
      "NotebookEdit",
      "WebFetch",
      "WebSearch",
      "Agent",
      "Bash",
      "LSP",
      "SendMessage",
      "AskUserQuestion",
      "TaskCreate",
      "TaskGet",
      "TaskList",
      "TaskUpdate",
      "TaskStop",
      "TaskOutput",
      "EnterPlanMode",
      "ExitPlanMode",
      "EnterWorktree",
      "ExitWorktree",
      "TeamCreate",
      "TeamDelete",
      "CronCreate",
      "CronDelete",
      "CronList",
      "Skill",
      "ToolSearch",
      "ReadMcpResourceTool",
      "ListMcpResourcesTool",
      "mcp__*"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(terraform destroy:*)",
      "Bash(terraform apply:*)",
      "Bash(tofu destroy:*)",
      "Bash(tofu apply:*)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(aws * create-:*)",
      "Bash(aws * delete-:*)",
      "Bash(aws * terminate-:*)",
      "Bash(aws * modify-:*)",
      "Bash(aws * update-:*)",
      "Bash(aws cloudformation create:*)",
      "Bash(aws cloudformation delete:*)",
      "Bash(aws cloudformation update:*)",
      "Bash(kubectl delete:*)",
      "Bash(kubectl apply:*)",
      "Bash(helm install:*)",
      "Bash(helm upgrade:*)",
      "Bash(helm uninstall:*)",
      "Bash(docker rm:*)",
      "Bash(docker rmi:*)",
      "Bash(docker stop:*)",
      "Bash(docker kill:*)"
    ]
  },
  "enabledMcpjsonServers": [
    "code-search",
    "memory",
    "fetch",
    "terraform",
    "opentofu",
    "atlassian",
    "aws-mcp"
  ]
}
